<?xml version="1.0" encoding="UTF-8"?>
<!--
  Talos EPP Agent — MSI definition (WiX v4/v5).

  This is the enterprise deployment artifact (GPO/SCCM/Intune expect an MSI).
  Silent install:
     msiexec /i talos-agent.msi /qn /norestart TENANT_TOKEN=xxx UPDATE_RING=delayed
  Built in CI on a Windows runner (see .github/workflows/ci.yml); the scanner
  binary must be compiled to the windows target first.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
      Name="Talos EPP Agent"
      Manufacturer="Talos Security"
      Version="0.12.0"
      UpgradeCode="6B5F9C2E-2D1A-4E3B-9C7A-1F2E3D4C5B6A"
      Scope="perMachine"
      InstallerVersion="500"
      Compressed="yes">

    <SummaryInformation Description="Talos EPP Agent (Phase 1 MVP)" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Silent-deployment configuration, set via msiexec properties or an MST
         transform. These flow into HKLM for the agent to read on first run. -->
    <Property Id="TENANT_TOKEN" Secure="yes" />
    <Property Id="SERVER" Value="https://cloud.talos.example" Secure="yes" />
    <Property Id="UPDATE_RING" Value="stable" Secure="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Talos EPP">
        <Directory Id="SIGDIR" Name="signatures">
          <Directory Id="SIGHASH" Name="hashes" />
          <Directory Id="SIGYARA" Name="yara" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <Feature Id="Main" Title="Talos EPP Agent" Level="1">
      <ComponentGroupRef Id="AgentComponents" />
    </Feature>

    <ComponentGroup Id="AgentComponents">
      <Component Directory="INSTALLFOLDER">
        <File Id="ScannerExe"
              Source="$(sys.SOURCEFILEDIR)..\..\target\x86_64-pc-windows-msvc\release\talos.exe"
              KeyPath="yes" />
      </Component>

      <!-- The always-on agent service binary, registered as an auto-start
           LocalSystem Windows Service that hosts real-time protection, the
           ransomware canary guard, and OS-firewall C2 blocking. The SCM
           launches it as `talos-agent.exe service-run`. -->
      <Component Directory="INSTALLFOLDER">
        <File Id="AgentExe"
              Source="$(sys.SOURCEFILEDIR)..\..\target\x86_64-pc-windows-msvc\release\talos-agent.exe"
              KeyPath="yes" />
        <ServiceInstall Id="TalosAgentService"
                        Name="TalosAgent"
                        DisplayName="Talos EPP Agent"
                        Description="Talos EPP endpoint protection agent — real-time on-access scanning with auto-quarantine, ransomware canary guard, and OS-firewall C2 blocking."
                        Type="ownProcess"
                        Start="auto"
                        ErrorControl="normal"
                        Arguments="service-run"
                        Account="LocalSystem"
                        Vital="yes" />
        <ServiceControl Id="TalosAgentControl"
                        Name="TalosAgent"
                        Start="install"
                        Stop="both"
                        Remove="uninstall"
                        Wait="no" />
      </Component>

      <Component Directory="INSTALLFOLDER">
        <File Id="GuiExe"
              Source="$(sys.SOURCEFILEDIR)..\..\target\x86_64-pc-windows-msvc\release\talos-gui.exe"
              KeyPath="yes" />
      </Component>

      <Component Directory="SIGHASH">
        <File Source="$(sys.SOURCEFILEDIR)..\..\signatures\hashes\baseline.hashdb" KeyPath="yes" />
      </Component>
      <Component Directory="SIGHASH">
        <File Id="TalosHashdb" Source="$(sys.SOURCEFILEDIR)..\..\signatures\hashes\talos.hashdb" KeyPath="yes" />
      </Component>
      <Component Directory="SIGYARA">
        <File Id="EicarYar" Source="$(sys.SOURCEFILEDIR)..\..\signatures\yara\eicar.yar" KeyPath="yes" />
      </Component>
      <Component Directory="SIGYARA">
        <File Id="WebshellsYar" Source="$(sys.SOURCEFILEDIR)..\..\signatures\yara\webshells.yar" KeyPath="yes" />
      </Component>
      <Component Directory="SIGYARA">
        <File Id="PowershellYar" Source="$(sys.SOURCEFILEDIR)..\..\signatures\yara\powershell.yar" KeyPath="yes" />
      </Component>

      <!-- Persist enrollment/config from the silent-install properties so the
           agent auto-enrolls to the correct tenant on first check-in. -->
      <Component Directory="INSTALLFOLDER" Guid="A2C4E6F8-1B3D-5F7A-9C0E-2D4F6A8C0E11">
        <RegistryKey Root="HKLM" Key="SOFTWARE\Talos EPP">
          <RegistryValue Name="TenantToken" Type="string" Value="[TENANT_TOKEN]" KeyPath="yes" />
          <RegistryValue Name="Server" Type="string" Value="[SERVER]" />
          <RegistryValue Name="UpdateRing" Type="string" Value="[UPDATE_RING]" />
          <RegistryValue Name="Version" Type="string" Value="0.12.0" />
        </RegistryKey>
      </Component>
    </ComponentGroup>

    <!--
      The user-mode TalosAgent service is installed above (ServiceInstall /
      ServiceControl). Phase 2 hardens it into an anti-malware **PPL**
      (protected process light) anchored by an **ELAM** driver, and adds the
      kernel sensor (minifilter / WFP). See docs/01-core-architecture.md and
      docs/04-deployment-distribution.md.
    -->
  </Package>
</Wix>
